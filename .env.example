# 🤖 Discord AI Agent - Environment Configuration Template

# --- DISCORD SECRETS ---
# Get your token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# --- AI PROVIDER API KEYS ---
# Required for the provider you choose in AI_PROVIDER
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIzaSy...
OPENROUTER_API_KEY=sk-or-v1-...
POLLINATIONS_API_KEY=sk_...
TAVILY_API_KEY=tvly-...

# --- MODEL SELECTION ---
# Options: "openai", "google", "openrouter", "local", "pollinations"
AI_PROVIDER=openrouter
AI_MODEL_NAME=openrouter/healer-alpha

# --- SECURITY & ADMIN ---
# Comma-separated Discord User IDs for bot administrators
ADMIN_USER_IDS=123456789123

# --- BOT BEHAVIOR (INITIAL DEFAULTS) ---
# Content for proactive greeting when the bot starts (if enabled in config)
AUTO_MESSAGE_CONTENT="👋 Hello! I am your AI Agent. Ask me anything!"

# --- ADVANCED: LANGSMITH TRACING (Optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT="Discord-Community-Agent"
